# ===========================================================================
# Tanvir Attire — environment configuration
# Copy to .env and fill in. Empty DB_* → app uses a local JSON file (dev only).
# ===========================================================================

# --- Stripe (test keys for dev, live keys for production) ---
STRIPE_SECRET_KEY=sk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From the Stripe Dashboard → Developers → Webhooks (the signing secret).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- MySQL (Hostinger remote DB). Leave blank to use the JSON-file fallback. ---
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
# Set to true if your host requires TLS for remote MySQL.
DB_SSL=false

# --- SMTP (Hostinger mailbox → new-order emails via nodemailer) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=order@yourdomain.com
SMTP_PASS=
MAIL_FROM=Tanvir Attire <order@yourdomain.com>
# New-order notifications go to these (comma-separated). Defaults already set in code.
ORDER_NOTIFY_TO=aarsayem002@gmail.com, Tanvirmahmudparvez@gmail.com

# --- Admin dashboard auth ---
ADMIN_EMAIL=admin@tanvirattire.com.au
# Plaintext is fine for dev; for production prefer ADMIN_PASSWORD_HASH instead.
ADMIN_PASSWORD=change_me_in_production
# Optional scrypt hash "<saltHex>:<hashHex>" (generate with: npm run gen-admin-hash "yourpass").
ADMIN_PASSWORD_HASH=
# Long random string used to sign admin session tokens.
ADMIN_SESSION_SECRET=
